# ─── Pool Indy ────────────────────────────────────────────────────────────────
# URL do genesis do VON Network (ou caminho local para o arquivo .txn)
# No cluster das baias, cada supernodo tem seu próprio genesis endpoint.
# Para teste local com von-network em Docker: http://host.docker.internal:9000/genesis
GENESIS_URL=http://von-network:9000/genesis

# ─── Trustee ──────────────────────────────────────────────────────────────────
# Seed e DID do Trustee1 padrão do VON Network
TRUSTEE_SEED=000000000000000000000000Trustee1
TRUSTEE_DID=V4SGRU86Z58d6TV7PBUe6f

# ─── Wallets ──────────────────────────────────────────────────────────────────
# Chave de criptografia das wallets (aries-askar, método "raw")
# Gere com: python3 -c "import secrets, base58; print(base58.b58encode(secrets.token_bytes(32)).decode())"
WALLET_KEY=7h3gFmD4QZdGdzt2NDtTg3XZwXFENBa1ogAgwHBxHNpw

# ─── Modelos (amostras JSON) ──────────────────────────────────────────────────
# Diretório com os 7 arquivos JSON extraídos do PostgreSQL.
# Dentro do container Docker: /app/models (embutido na imagem via COPY client/ .)
# Para execução local fora do Docker: ./client/models
MODELS_DIR=/app/models

# ─── Concorrência ─────────────────────────────────────────────────────────────
# Número de registros paralelos dentro de cada nível da cadeia.
# 1 = sequencial (padrão). Aumente para estressar o ledger no experimento.
CONCURRENCY=1

# ─── Saída ────────────────────────────────────────────────────────────────────
METRICS_OUTPUT=/app/output/raw_tx_metrics.csv

# ─── Log ──────────────────────────────────────────────────────────────────────
# Níveis disponíveis: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── COTTON-NET (opcional) ────────────────────────────────────────────────────
# URL do Coordinator RAFT. Se definido, o client usa consenso externo (RAFT)
# em vez de submeter transações diretamente ao ledger Indy.
# Deixe em branco (ou comente) para modo direto (COTTONTRUST original).
# No cluster: http://coordinator-1:8000
# COORDINATOR_URL=http://coordinator-1:8000

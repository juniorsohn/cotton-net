# ─── Pool Indy ────────────────────────────────────────────────────────────────
# URL do genesis do VON Network (ou caminho local para o arquivo .txn)
GENESIS_URL=http://von-network:9000/genesis

# ─── Trustee ──────────────────────────────────────────────────────────────────
# Seed e DID do Trustee1 padrão do VON Network
# Não altere esses valores se estiver usando o VON Network padrão
TRUSTEE_SEED=000000000000000000000000Trustee1
TRUSTEE_DID=V4SGRU86Z58d6TV7PBUe6f

# ─── Wallets ──────────────────────────────────────────────────────────────────
# Chave de criptografia das wallets (aries-askar, método "raw")
WALLET_KEY=changeme_in_production

# ─── Dados de entrada ─────────────────────────────────────────────────────────
MODELS_DIR=/app/models

# ─── Saída ────────────────────────────────────────────────────────────────────
METRICS_OUTPUT=/app/output/raw_tx_metrics.csv

# ─── Log ──────────────────────────────────────────────────────────────────────
# Níveis disponíveis: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── COTTON-NET (opcional) ────────────────────────────────────────────────────
# URL do Coordinator RAFT. Se definido, o client usa consenso externo (RAFT)
# em vez de submeter transações diretamente ao ledger Indy.
# Deixe em branco para modo direto (COTTONTRUST original).
# COORDINATOR_URL=http://coordinator-1:8000
